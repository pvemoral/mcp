# ── Required ──────────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=mystorageaccount

# ── Authentication (choose ONE method) ───────────────────────────────────────

# Option A – SAS Token (scoped, time-limited)
AZURE_STORAGE_SAS_TOKEN=

# Option B – Service Principal (recommended for production)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Option C – DefaultAzureCredential (managed identity / az login)
# No extra variables needed – just leave all above empty

# ── Optional ──────────────────────────────────────────────────────────────────
# Default filesystem/container used when tools omit the 'filesystem' parameter
AZURE_STORAGE_FILESYSTEM=
